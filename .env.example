# ══════════════════════════════════════════════════════════════
#  TaskGraph AI Service Bridge — Environment Variables
# ══════════════════════════════════════════════════════════════
#  Copy this file to .env and fill in the values:
#    cp .env.example .env
# ══════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────

# Display name (shown in health-check / logs)
APP_NAME="TaskGraph AI Service Bridge"

# Semantic version reported by /health and OpenAPI schema
APP_VERSION=1.0.0

# Enable debug mode (verbose logging, detailed error responses)
# In production always set to false
DEBUG=false

# ── Security ──────────────────────────────────────────────────

# Shared secret between Core API (Spring Boot) and this service.
# Every request must include the header  X-Internal-Secret: <value>
# REQUIRED — the service will NOT start without it.
INTERNAL_SECRET=change-me-to-a-random-secret

# ── CORS ──────────────────────────────────────────────────────

# Comma-separated list of allowed origins.
# Use "*" only for local development.
CORS_ORIGINS=*

# ── Reverse Proxy ─────────────────────────────────────────────

# Sub-path prefix when behind nginx (e.g. /api/v1/ai).
# Tells Swagger UI where to find openapi.json.
# Leave empty for local development.
ROOT_PATH=

# ── Redis / Celery ────────────────────────────────────────────

# Redis connection URL used by Celery as both broker and result backend.
# Format: redis://<host>:<port>/<db>
REDIS_URL=redis://localhost:6379/0
